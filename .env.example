# World Cup Alpha - Environment Configuration
# Copy this file to .env and fill in your API keys and credentials.
# Never commit .env to version control.

# TheOddsAPI
# Get your free API key at https://theoddsapi.com
# Free tier covers major markets (1x2, over/under, spreads) but with daily/hourly rate limits.
ODDS_API_KEY=your_odds_api_key_here

# Betfair (UK-based betting exchange)
# Register at https://www.betfair.com and create an app key.
# Username and password are your Betfair login credentials.
# App key is generated under Settings > Developer's Tools > Application Keys.
BETFAIR_APP_KEY=your_betfair_app_key_here
BETFAIR_USERNAME=your_betfair_username_here
BETFAIR_PASSWORD=your_betfair_password_here

# Optional: Polymarket / onchain market data
# For future integration with crypto prediction markets.
# POLYMARKET_API_KEY=your_polymarket_key_here
# UNISWAP_RPC_URL=your_ethereum_rpc_url_here

# Optional: Logging & debugging
# LOG_LEVEL=INFO
# DEBUG=false
