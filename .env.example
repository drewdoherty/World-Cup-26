# World Cup Alpha — environment configuration
# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Keys below are grouped by the service that needs them (see deploy/README.md).

# ─── Odds + model pipeline (NO VPN needed) ──────────────────────────────────
# TheOddsAPI key — https://the-odds-api.com  (card, snapshots, closing lines)
ODDS_API_KEY=your_odds_api_key_here

# ─── Telegram bot (needs the EU VPN — Telegram is blocked from Bahrain) ──────
# Bot token from @BotFather; your numeric user id from @userinfobot.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_USER_ID=your_numeric_user_id_here   # who can confirm "Y PM-n"
TELEGRAM_CHAT_ID=your_chat_id_here                 # where cards/alerts post
WCA_NEWS_CHAT_ID=your_news_chat_id_here            # optional: news feed channel

# ─── Polymarket trading (needs non-UK/US network; works native from Bahrain) ─
POLYMARKET_FUNDER=0xyour_maker_wallet_address_here
POLYMARKET_SIG_TYPE=0
# SECURITY: prefer the macOS Keychain over putting the raw key here. Leave this
# blank and have the PM trader read the key from Keychain on the Mac Mini.
POLYMARKET_PRIVATE_KEY=
# Execution gate: keep 1 (dry-run) until one full propose->Telegram->Y->execute
# cycle has succeeded, then set 0 to go live on-chain.
PM_DRY_RUN=1

# ─── Screenshot ingest (offer/bet-slip OCR) ─────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_VISION_MODEL=claude-opus-4-8

# ─── Publishing / misc ──────────────────────────────────────────────────────
# Private/local mode is the default. The bot/daemons regenerate site JSON but do
# not push to GitHub/Vercel unless this is explicitly set to 1.
WCA_AUTOPUSH=0
# PORT=8742   # optional: local site server (scripts/wca_local_site.py)

# ─── Legacy / optional (not read by the current pipeline) ───────────────────
# BETFAIR_APP_KEY=
# BETFAIR_USERNAME=
# BETFAIR_PASSWORD=
