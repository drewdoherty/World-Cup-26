# World Cup Alpha — @WorldCupDev dev-conductor config (runs on the Mac mini)
#
# Copy to .env.conductor and fill in. NEVER commit .env.conductor (it is gitignored).
# This is DEV/DRY-RUN infrastructure: it fans dev tasks out to headless coding
# agents (one git worktree + branch + PR each) and NEVER touches the live ledger.
# The conductor REFUSES to start if WCA_DB_PATH resolves to wca.db.
#
#   cp .env.conductor.example .env.conductor
#   # edit the values below, then:
#   bash deploy/macmini/install.sh        # registers the 'conductor' launchd daemon

# ─── @WorldCupDev Telegram bot (a SEPARATE BotFather bot from @gamble1_bot) ──
TELEGRAM_BOT_TOKEN=your_worldcupdev_bot_token_here
TELEGRAM_ADMIN_USER_ID=your_numeric_user_id_here   # only you can dispatch / /merge
TELEGRAM_CHAT_ID=your_chat_id_here                 # where the conductor talks
# WCA_CONDUCTOR_NOTIFY_CHAT=                        # optional; defaults to TELEGRAM_CHAT_ID

# ─── Safety: dry-run + dev DB (load-bearing — keep these) ────────────────────
PM_DRY_RUN=1
WCA_DB_PATH=data/dev.db

# ─── Swarm sizing ────────────────────────────────────────────────────────────
# Sequential by default (collision-safe). Raise to run a parallel swarm.
WCA_CONDUCTOR_MAX_PARALLEL=1
# Codex is exhausted → Claude-only. Drop this line to re-enable Codex routing.
WCA_CONDUCTOR_DISABLED_ENGINES=codex
# WCA_CONDUCTOR_TOKEN_BUDGET=0                      # 0 = unlimited

# ─── Headless agent CLIs (absolute paths if off-PATH on the mini) ────────────
CLAUDE_BIN=claude        # the conductor needs the `claude` CLI installed here
CODEX_BIN=codex
GH_BIN=gh                # gh must be authenticated on the mini (gh auth login)

# ─── Claude auth for headless agents (portable subscription token) ───────────
# Mint on the mini with:  claude setup-token   (prints sk-ant-oat01-...)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your_token_here
