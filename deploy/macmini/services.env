# Shared service definitions for the Mac mini production host.
# Sourced by install.sh, uninstall.sh, autopull.sh.
#
# Long-running daemons (KeepAlive — restarted if they die, started at boot).
#   bot        : @gamble1_bot betting bot (live env .env)
#   conductor  : @WorldCupDev dev-conductor — DRY-RUN env .env.conductor (never the
#                live ledger; it refuses to start if WCA_DB_PATH resolves to wca.db).
#                Create .env.conductor (from .env.conductor.example) BEFORE install,
#                or it crash-loops on a missing bot token.
WCA_DAEMONS=(bot snapshotd newsd promosd conductor)

# Interval jobs (StartInterval seconds).
#   autopull     : pull latest code from origin/main and restart changed services
#   buildcard    : rebuild the model card for upcoming fixtures (fast; --skip-scorers)
#   goalscorers  : refresh ONLY the /goalscorers card with real scorer markets
#                  (--goalscorers-only); buildcard skips scorers to save quota and
#                  no longer touches this card, so this job keeps it populated
#   backup       : rotating local snapshot of the ledger DB
#   pmpropose    : park + send Polymarket trade proposals to Telegram
#   pmredeem     : cancel Polymarket orders unfilled past 24h (emulated GTD)
#   closecapture : stamp closing_odds + CLV on settled bets
#   publish      : rebuild the static site and auto-commit/push it
#   watchdog     : liveness check — alerts Telegram if any KeepAlive daemon is
#                  down / crash-looping / never-bootstrapped. KeepAlive respawns
#                  a crash but is otherwise SILENT, so a flapping daemon = stale
#                  data with no warning. Read-only; never restarts anything.
#   positions    : reconcile venue positions (Betfair/Smarkets/Polymarket)
#                  against the ledger. SHADOW by default (logs proposed changes +
#                  refreshes the read-only site projection, ZERO ledger writes);
#                  promote to LIVE writes by exporting WCA_POSITIONS_LIVE=1.
#                  NOTE (v2): Betfair is UNREACHABLE from the mini, so the
#                  cross-machine path (deploy/macbook/) fetches open + settled-24h
#                  on the MacBook (VPN) and APPLIES to this ledger over SSH via
#                  `wca_positions_sync.py --apply-from-snapshot`. This mini job
#                  still runs as a Smarkets/PM-only fallback (Betfair degrades to
#                  []) and applies its own reconciliation locally.
#   archive      : durable data-archival snapshot — compressed wca.db copy +
#                  bets parquet export + verbatim capture of the current model
#                  outputs (card/predictions/advancement) into the partitioned
#                  parquet archive (data/archive by default; mirrors to cloud
#                  object storage if WCA_ARCHIVE_S3_* creds are set). READ-ONLY
#                  w.r.t. wca.db (online-backup copy; never mutates the ledger).
#                  Raw odds/PM/Betfair payloads are teed inline by the clients;
#                  this job covers the scheduled, non-fetch artifacts.
#   pmdrift      : hourly DRIFT ALERT — diffs the live Polymarket account (Data
#                  API, read-only, both proxy wallets) against the bets ledger and
#                  DMs the admin if they diverge (positions placed manually in the
#                  PM app never become ledger rows, so whole-book exposure silently
#                  under-counts). Read-only: never writes the ledger, never trades.
#                  Reconcile with `wca_pm_reconcile.py --apply` after a backup.
#   analytics    : regenerate the 8001 analytics feeds (winrate/rigor/risk_pnl/
#                  clvbench/tracking/exposure) from the live ledger AND replay
#                  the prediction ledger (predledger backfill -> data/dev.db
#                  predictions) so the venues benchmark has its input. These
#                  feeds previously had NO scheduled regen (they went stale at
#                  06-25). Read-only w.r.t. wca.db; writes only dev.db + feeds.
#   venues       : Model-vs-Venue benchmark feed (needs data/dev.db predictions,
#                  populated by the analytics job's predledger backfill).
#   pm1x2snapshot: capture Polymarket match-winner (h2h) prices into
#                  odds_snapshots so 'venues' can rank Polymarket instead of
#                  showing it COLLECTING forever. POSTMORTEM (2026-07-02): the
#                  capture pipeline (src/wca/pm1x2snapshot.py) and its CLI
#                  (scripts/wca_pm_1x2_snapshot.py) shipped in #109 but were
#                  never added here — a full day ran with zero rows captured
#                  and nobody told. --notify makes a persistently-stale (or
#                  never-populated) snapshot page the admin instead of sitting
#                  quiet; see the freshness gate in the script itself.
#   orderflow    : hourly PM orderflow fill capture (scripts/wca_orderflow_refresh.sh).
#                  The Polymarket data-api /trades endpoint hard-caps history at
#                  offset 3000 per market and busy match markets blow through
#                  3000 fills within hours — a missed window permanently loses
#                  that match-day fill history, so this MUST keep running while
#                  markets are open (after close the tape is frozen). Appends to
#                  data/pm_orderflow.db and rebuilds site/microstructure/
#                  orderflow.json (pushed by 'publish'). Read-only w.r.t. wca.db.
#   propcal      : rebuild data/prop_calibration.json (corners/cards NB
#                  calibration off model lambdas + team EB priors — scripts/
#                  wca_prop_calibration.py). P4: this feed never existed, so
#                  wca_betrecs.py's event_props section was permanently empty
#                  (only the standing "scorer props unsupported" withheld row
#                  ever showed). Read-only w.r.t. wca.db; still FREE-BET-ONLY
#                  (no live book price snapshot) — build_event_props keeps
#                  withholding these from cash regardless of this feed.
WCA_INTERVAL_JOBS=(autopull buildcard goalscorers backup pmpropose pmredeem closecapture publish watchdog positions archive pmdrift analytics venues pm1x2snapshot orderflow playersdb propcal)
WCA_INTERVAL_autopull=300      # 5 min
WCA_INTERVAL_buildcard=1800    # 30 min
WCA_INTERVAL_goalscorers=10800 # 3 h — per-event scorer pulls (≤5 fixtures), quota-light
WCA_INTERVAL_backup=900        # 15 min
WCA_INTERVAL_pmpropose=1800    # 30 min
WCA_INTERVAL_pmredeem=3600     # 60 min
WCA_INTERVAL_closecapture=600  # 10 min
WCA_INTERVAL_publish=1800      # 30 min — PRIMARY site-feed refresh (regen + commit/push); Actions cron is only a 4x/day backup
WCA_INTERVAL_watchdog=300      # 5 min
WCA_INTERVAL_positions=3600    # 60 min — venue-position reconciliation (SHADOW)
WCA_INTERVAL_archive=21600     # 6 h — ledger snapshot + model-output capture
WCA_INTERVAL_pmdrift=3600      # 60 min — PM live-account vs ledger drift ALERT (read-only)
WCA_INTERVAL_analytics=3600    # 60 min — regenerate 8001 analytics feeds + predledger backfill
WCA_INTERVAL_venues=7200       # 2 h — Model-vs-Venue benchmark feed (after analytics)
WCA_INTERVAL_pm1x2snapshot=1800 # 30 min — PM 1X2 capture (before 'venues'); --notify on silent stall
WCA_INTERVAL_orderflow=3600    # 60 min — PM orderflow fill capture (data-api 3000-offset cap; gaps are permanent); read-only w.r.t. wca.db

# launchd label prefix
WCA_LABEL_PREFIX="com.wca"
WCA_INTERVAL_playersdb=86400  # daily — StatsBomb per-match backfill (cached) + players.db aggregate rebuild
WCA_INTERVAL_propcal=1800     # 30 min — prop_calibration.json rebuild (after buildcard refreshes model_predictions.json)
