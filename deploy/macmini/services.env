# Shared service definitions for the Mac mini production host.
# Sourced by install.sh, uninstall.sh, autopull.sh.
#
# Long-running daemons (KeepAlive — restarted if they die, started at boot).
#   bot        : @gamble1_bot betting bot (live env .env)
#   conductor  : @WorldCupDev dev-conductor — DRY-RUN env .env.conductor (never the
#                live ledger; it refuses to start if WCA_DB_PATH resolves to wca.db).
#                Create .env.conductor (from .env.conductor.example) BEFORE install,
#                or it crash-loops on a missing bot token.
WCA_DAEMONS=(bot snapshotd newsd promosd conductor)

# Interval jobs (StartInterval seconds).
#   autopull     : pull latest code from origin/main and restart changed services
#   buildcard    : rebuild the model card for upcoming fixtures (fast; --skip-scorers)
#   goalscorers  : refresh ONLY the /goalscorers card with real scorer markets
#                  (--goalscorers-only); buildcard skips scorers to save quota and
#                  no longer touches this card, so this job keeps it populated
#   backup       : rotating local snapshot of the ledger DB
#   pmpropose    : park + send Polymarket trade proposals to Telegram
#   pmredeem     : cancel Polymarket orders unfilled past 24h (emulated GTD)
#   closecapture : stamp closing_odds + CLV on settled bets
#   publish      : rebuild the static site and auto-commit/push it
#   watchdog     : liveness check — alerts Telegram if any KeepAlive daemon is
#                  down / crash-looping / never-bootstrapped. KeepAlive respawns
#                  a crash but is otherwise SILENT, so a flapping daemon = stale
#                  data with no warning. Read-only; never restarts anything.
#   positions    : reconcile venue positions (Betfair/Smarkets/Polymarket)
#                  against the ledger. SHADOW by default (logs proposed changes +
#                  refreshes the read-only site projection, ZERO ledger writes);
#                  promote to LIVE writes by exporting WCA_POSITIONS_LIVE=1.
#                  NOTE (v2): Betfair is UNREACHABLE from the mini, so the
#                  cross-machine path (deploy/macbook/) fetches open + settled-24h
#                  on the MacBook (VPN) and APPLIES to this ledger over SSH via
#                  `wca_positions_sync.py --apply-from-snapshot`. This mini job
#                  still runs as a Smarkets/PM-only fallback (Betfair degrades to
#                  []) and applies its own reconciliation locally.
WCA_INTERVAL_JOBS=(autopull buildcard goalscorers backup pmpropose pmredeem closecapture publish watchdog positions)
WCA_INTERVAL_autopull=300      # 5 min
WCA_INTERVAL_buildcard=1800    # 30 min
WCA_INTERVAL_goalscorers=10800 # 3 h — per-event scorer pulls (≤5 fixtures), quota-light
WCA_INTERVAL_backup=900        # 15 min
WCA_INTERVAL_pmpropose=1800    # 30 min
WCA_INTERVAL_pmredeem=3600     # 60 min
WCA_INTERVAL_closecapture=600  # 10 min
WCA_INTERVAL_publish=3600      # 60 min
WCA_INTERVAL_watchdog=300      # 5 min
WCA_INTERVAL_positions=3600    # 60 min — venue-position reconciliation (SHADOW)

# launchd label prefix
WCA_LABEL_PREFIX="com.wca"
