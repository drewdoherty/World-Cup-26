# Shared service definitions for the Mac mini production host.
# Sourced by install.sh, uninstall.sh, autopull.sh.
#
# Long-running daemons (KeepAlive — restarted if they die, started at boot).
#   bot        : @gamble1_bot betting bot (live env .env)
#   conductor  : @WorldCupDev dev-conductor — DRY-RUN env .env.conductor (never the
#                live ledger; it refuses to start if WCA_DB_PATH resolves to wca.db).
#                Create .env.conductor (from .env.conductor.example) BEFORE install,
#                or it crash-loops on a missing bot token.
WCA_DAEMONS=(bot snapshotd newsd promosd conductor)

# Interval jobs (StartInterval seconds).
#   autopull     : pull latest code from origin/main and restart changed services
#   buildcard    : rebuild /card + /next + /goalscorers every 30 min (fast;
#                  --skip-scorers saves Odds-API quota). /goalscorers is now
#                  MODEL-priced from data/players.db on every run, so it refreshes
#                  at the SAME cadence as /card and is never stale (one source of
#                  truth — kills the old 30-min-vs-3-h split). Requires
#                  data/players.db (build with scripts/wca_build_players_db.py).
#   goalscorers  : OPTIONAL market-EV overlay top-up (--goalscorers-only) — adds
#                  live book/PM scorer prices on top of the model card a few times
#                  a day to keep quota low. Freshness no longer depends on it; it
#                  can be removed entirely if the model-only card is sufficient.
#   backup       : rotating local snapshot of the ledger DB
#   pmpropose    : park + send Polymarket trade proposals to Telegram
#   pmredeem     : cancel Polymarket orders unfilled past 24h (emulated GTD)
#   closecapture : stamp closing_odds + CLV on settled bets
#   publish      : rebuild the static site and auto-commit/push it
WCA_INTERVAL_JOBS=(autopull buildcard goalscorers backup pmpropose pmredeem closecapture publish)
WCA_INTERVAL_autopull=300      # 5 min
WCA_INTERVAL_buildcard=1800    # 30 min — also refreshes /goalscorers (model-priced)
WCA_INTERVAL_goalscorers=10800 # 3 h — OPTIONAL live market-EV overlay on the model card
WCA_INTERVAL_backup=900        # 15 min
WCA_INTERVAL_pmpropose=1800    # 30 min
WCA_INTERVAL_pmredeem=3600     # 60 min
WCA_INTERVAL_closecapture=600  # 10 min
WCA_INTERVAL_publish=3600      # 60 min

# launchd label prefix
WCA_LABEL_PREFIX="com.wca"
