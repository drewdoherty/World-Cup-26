.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.env
.env.dev
.env.conductor
data/raw/*
data/processed/*
data/*.db
!data/raw/.gitkeep
!data/processed/.gitkeep
# The cleaned, verified results dataset IS a tracked deliverable (raw mirror is
# not — it is re-downloaded). Rebuilt by scripts/wca_clean_results.py.
!data/raw/martj42_cleaned.csv
.DS_Store
.claude/
worktrees/
logs/*
!logs/.gitkeep
!data/raw/snapshots/
!data/processed/wc2026_results.json

# SQLite WAL sidecars (live DB state — never track)
data/*.db-shm
data/*.db-wal

# Betfair session-token cache (secret — never track)
data/.betfair_session.json

# runtime logs + DB backups (never track)
data/com.wca.*.log
data/*.db.*
.env.bak.*

# dev-conductor: pasted screenshots are debug input only — never track them
data/conductor_uploads/
.conductor_inbox/

# data-archival pipeline output (parquet archive + ledger DB snapshots) — this
# is durable runtime data, mirrored to cloud object storage; never tracked here.
data/archive/


# host-local Polymarket exact-score cache (written by wca_scores_data / wca_forest_data)
data/pm_exactscore_cache.json

# PM order/fill lifecycle telemetry (wca.pm.filltelemetry) — append-only
# runtime log written by the live trader/bot, never a tracked deliverable.
data/pm_fill_log.jsonl

# In-play monitor runtime artifacts (scripts/wca_pm_inplay_monitor.py /
# wca_pm_inplay_ingest.py). NOTE data/pm_inplay_proposals.json IS tracked —
# it is the git artifact relay. These are host-local runtime state only:
data/pm_inplay_log.jsonl
data/pm_inplay_pings.log
data/.pm_inplay_ingested.json
data/live_scores.json
